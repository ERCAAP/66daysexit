# App Configuration
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=https://api.phoenix66days.com
EXPO_PUBLIC_APP_VERSION=1.0.0

# Analytics & Monitoring (Optional)
